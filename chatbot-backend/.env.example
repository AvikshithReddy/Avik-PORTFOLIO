CHAT_MAX_TOKENS=800

# RAG
RAG_RETRIEVER_TOP_K=12
RAG_RERANK_TOP_N=8
RAG_TOP_K=6
RAG_CHUNK_SIZE=1100
RAG_CHUNK_OVERLAP=150
RAG_CODE_CHUNK_LINES=120
RAG_CODE_CHUNK_OVERLAP=20
